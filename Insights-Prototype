      <div style="display:flex;justify-content:space-between;align-items:flex-start">
        <div>
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px">
            <span style="font-size:15px;font-weight:500;color:#2E3751">${l.name}</span>${ib(l.interest)}
          </div>
          <div class="body">${l.program} · ${l.mobile}</div>
          <div class="meta" style="margin-top:2px">Last contacted ${l.contacted}</div>
        </div>
        <button class="btn btn-ghost btn-sm" onclick="closePanel()" style="padding:4px 7px"><svg width="13" height="13" fill="currentColor" viewBox="0 0 20 20"><path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z"/></svg></button>
      </div>
    </div>
    <div class="sp-act">
      <button class="btn btn-primary" style="flex:1;justify-content:center;font-size:12px">Call Now</button>
      <button class="btn" style="flex:1;justify-content:center;font-size:12px">Schedule Follow-Up</button>
    </div>
    <div class="sp-body">
      <button class="btn btn-purple btn-sm" style="width:100%;justify-content:center;margin-bottom:13px" onclick="closePanel();openLeadFull(${id})">Open Full Lead Detail →</button>
      <div class="tabs" style="margin-bottom:0">
        <button class="tab active" style="font-size:11px;padding:6px 0;margin-right:14px" onclick="setPTab('calls',this,${id})">Call History</button>
        <button class="tab" style="font-size:11px;padding:6px 0;margin-right:14px" onclick="setPTab('info',this,${id})">Lead Info</button>
        <button class="tab" style="font-size:11px;padding:6px 0" onclick="setPTab('notes',this,${id})">Notes</button>
      </div>
      <div id="pTabBody" style="margin-top:14px">${pCallsTab(calls)}</div>
    </div>`);
}

function setPTab(t,btn,id){
  document.querySelectorAll('.sp-body .tab').forEach(b=>b.classList.remove('active'));btn.classList.add('active');
  const l=D.leads.find(x=>x.id===id);const calls=D.calls.filter(c=>c.leadId===id);
  document.getElementById('pTabBody').innerHTML={calls:()=>pCallsTab(calls),info:()=>pInfoTab(l),notes:()=>pNotesTab()}[t]();}
function pCallsTab(calls){return`<div class="sec-lbl">${calls.length} call${calls.length!==1?'s':''} recorded</div>
  ${calls.map(c=>`<div class="call-card" onclick="openCallPanel('${c.id}')">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:5px">
      <span style="font-size:11px;font-weight:500;color:#2E3751">${c.date} · ${c.time}</span>${sb(c.score)}
    </div>
    <div style="display:flex;gap:12px"><span class="meta">Duration: ${c.dur}</span><span style="font-size:10px;color:#6832BA;font-weight:500">View AI Breakdown</span></div>
  </div>`).join('')}
  ${calls[0]?`<hr class="divider">
    <div class="sec-lbl">Concerns from last call</div>
    ${calls[0].concerns.map(c=>`<div class="blt"><span class="blt-dot" style="background:#F04438"></span><span class="body">${c}</span></div>`).join('')}
    <hr class="divider">
    <div class="sec-lbl">Next steps</div>
    ${calls[0].nextSteps.map(s=>`<div class="blt"><span class="blt-dot" style="background:#B1B8C4"></span><span class="body">${s}</span></div>`).join('')}`:''}`;
}
function pInfoTab(l){return`<div style="background:#F9FAFB;border-radius:8px;padding:12px;border:1px solid #EDEFF2">
  ${[['Program',l.program],['Mobile',l.mobile],['Email',l.email],['Source',l.source],['Created',l.created]].map(([k,v])=>`<div class="info-row"><span class="meta">${k}</span><span style="font-weight:500;color:#2E3751;font-size:12px">${v}</span></div>`).join('')}
</div>`;}
function pNotesTab(){return`<textarea class="inp" style="width:100%;min-height:80px;font-size:12px" placeholder="Add a note..."></textarea>
<button class="btn btn-primary btn-sm" style="margin-top:7px">Save Note</button>`;}

/* ── CALL PANEL ── */
function openCallPanel(id){
  S.callTab='score';
  const call=D.calls.find(c=>c.id===id);
  openPanel(`
    <div class="sp-hdr">
      <div style="display:flex;justify-content:space-between;align-items:center">
        <div style="display:flex;align-items:center;gap:7px">
          <button class="btn btn-ghost btn-sm" onclick="openLeadPanel(${call.leadId})" style="padding:4px 7px"><svg width="13" height="13" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M11.78 5.22a.75.75 0 0 1 0 1.06L8.06 10l3.72 3.72a.75.75 0 1 1-1.06 1.06l-4.25-4.25a.75.75 0 0 1 0-1.06l4.25-4.25a.75.75 0 0 1 1.06 0Z" clip-rule="evenodd"/></svg></button>
          <div>
            <div style="font-size:13px;font-weight:500;color:#2E3751">Call Breakdown</div>
            <div class="meta">${call.date} · ${call.time} · ${call.dur}</div>
          </div>
        </div>
        <button class="btn btn-ghost btn-sm" onclick="closePanel()" style="padding:4px 7px"><svg width="13" height="13" fill="currentColor" viewBox="0 0 20 20"><path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z"/></svg></button>
      </div>
    </div>
    <div class="sp-body">
      <div style="display:flex;justify-content:center;margin-bottom:12px">${gauge(call.score)}</div>
      <div class="tabs" style="margin-bottom:0">
        <button class="tab ${S.callTab==='score'?'active':''}" style="font-size:11px;padding:6px 0;margin-right:14px" onclick="setCTab('score',this,'${call.id}')">Call Score</button>
        <button class="tab ${S.callTab==='insights'?'active':''}" style="font-size:11px;padding:6px 0" onclick="setCTab('insights',this,'${call.id}')">Call Insights</button>
      </div>
      <div id="cTabBody" style="margin-top:14px">${cTabC(S.callTab,call)}</div>
    </div>
    <div style="padding:10px 20px;border-top:1px solid #E2E4E8;display:flex;gap:7px">
      <button class="btn btn-sm" style="flex:1;justify-content:center">Get Transcript</button>
      <button class="btn btn-primary btn-sm" style="flex:1;justify-content:center" onclick="openFUModal()">Schedule Follow-Up</button>
    </div>`);
}

function setCTab(t,btn,id){S.callTab=t;document.querySelectorAll('.sp-body .tab').forEach(b=>b.classList.remove('active'));btn.classList.add('active');document.getElementById('cTabBody').innerHTML=cTabC(t,D.calls.find(c=>c.id===id));}
function cTabC(t,call){
  if(t==='score')return`
    <div class="sec-lbl">Category Scores</div>
    ${D.catMeta.map(({key,label,w})=>{const pct=(call.cats[key]/5)*100;const col=barC(pct);return`<div style="margin-bottom:10px">
      <div style="display:flex;justify-content:space-between;margin-bottom:3px"><span class="body">${label}</span><span class="meta">${w}</span></div>
      <div class="sbar"><div class="sbar-track"><div class="sbar-fill" style="width:${pct}%;background:${col}"></div></div><span class="sbar-num" style="color:${col}">${call.cats[key]}</span></div>
    </div>`;}).join('')}
    <hr class="divider">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px">
      <div><div style="font-size:9px;font-weight:500;color:#039855;text-transform:uppercase;letter-spacing:.07em;margin-bottom:7px">Strengths</div>
        ${D.catMeta.filter(({key})=>call.cats[key]>=3).slice(0,3).map(({key,label})=>`<div class="blt"><span class="blt-dot" style="background:#1ACC73"></span><span class="meta">${label} (${call.cats[key]}/5)</span></div>`).join('')}</div>
      <div><div style="font-size:9px;font-weight:500;color:#D92D20;text-transform:uppercase;letter-spacing:.07em;margin-bottom:7px">To Improve</div>
        ${D.catMeta.filter(({key})=>call.cats[key]<=2).slice(0,3).map(({key,label})=>`<div class="blt"><span class="blt-dot" style="background:#F04438"></span><span class="meta">${label} (${call.cats[key]}/5)</span></div>`).join('')}</div>
    </div>
    <hr class="divider">
    <div class="sec-lbl">KSP Coverage</div>
    ${call.ksps.map(k=>`<div class="ksp-row">
      <div style="display:flex;align-items:center;gap:8px">
        <span style="width:16px;height:16px;border-radius:50%;background:${k.pitched?'#D1FADF':'#FEE4E2'};display:flex;align-items:center;justify-content:center;font-size:8px;font-weight:700;color:${k.pitched?'#039855':'#D92D20'};flex-shrink:0">${k.pitched?'✓':'✕'}</span>
        <span class="body">${k.name}</span>
      </div>
      <span class="badge" style="background:${k.pitched?'#D1FADF':'#FEE4E2'};color:${k.pitched?'#039855':'#D92D20'}">${k.pitched?'Pitched':'Not Pitched'}</span>
    </div>`).join('')}`;
  return`
    <div style="background:#F9FAFB;border:1px solid #EDEFF2;border-radius:8px;padding:12px;margin-bottom:13px">
      <div class="sec-lbl" style="margin-bottom:5px">Call Summary</div>
      <p class="body" style="line-height:1.6;font-size:12px">${call.summary}</p>
    </div>
    <div class="sec-lbl">Key Details</div>
    <p class="body" style="margin-bottom:13px;line-height:1.6;font-size:12px">${call.keyDetails}</p>
    <hr class="divider">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
      <div><div style="font-size:9px;font-weight:500;color:#039855;text-transform:uppercase;letter-spacing:.07em;margin-bottom:6px">Strengths</div><p class="body" style="font-size:12px;line-height:1.55">${call.strengths}</p></div>
      <div><div style="font-size:9px;font-weight:500;color:#D92D20;text-transform:uppercase;letter-spacing:.07em;margin-bottom:6px">Areas of Improvement</div><p class="body" style="font-size:12px;line-height:1.55">${call.improvements}</p></div>
    </div>
    <hr class="divider">
    <div class="sec-lbl">Lead Concerns</div>
    ${call.concerns.map(c=>`<div class="blt"><span class="blt-dot" style="background:#F04438"></span><span class="body">${c}</span></div>`).join('')}
    <div class="sec-lbl" style="margin-top:11px">Next Steps</div>
    ${call.nextSteps.map(s=>`<div class="blt"><span class="blt-dot" style="background:#B1B8C4"></span><span class="body">${s}</span></div>`).join('')}
    <hr class="divider">
    <div class="sec-lbl">Lead Assessment</div>
    ${ib(call.interest)}`;}

function openFUModal(){
  const m=document.createElement('div');
  m.style.cssText='position:fixed;inset:0;background:rgba(0,0,0,.3);display:flex;align-items:center;justify-content:center;z-index:300';
  m.innerHTML=`<div style="background:#fff;border-radius:12px;padding:22px;width:300px;box-shadow:0 16px 48px rgba(0,0,0,.15)">
    <div style="font-size:14px;font-weight:500;color:#2E3751;margin-bottom:14px">Schedule Follow-Up</div>
    <div class="field"><label>Date <span class="req">*</span></label><input type="date" class="inp" style="width:100%"></div>
    <div class="field"><label>Time <span class="req">*</span></label><input type="time" class="inp" style="width:100%"></div>
    <div style="display:flex;gap:7px;justify-content:flex-end;margin-top:4px">
      <button class="btn btn-sm" onclick="this.closest('[style*=fixed]').remove()">Cancel</button>
      <button class="btn btn-primary btn-sm" onclick="this.closest('[style*=fixed]').remove()">Done</button>
    </div>
  </div>`;
  document.body.appendChild(m);
}

/* ── COUNSELLOR DETAIL PANEL ── */
function openCounsellorPanel(id){
  const c=D.counsellors.find(x=>x.id===id);
  openPanel(`
    <div class="sp-hdr">
      <div style="display:flex;justify-content:space-between;align-items:center">
        <div style="display:flex;align-items:center;gap:11px">
          <div class="av" style="width:34px;height:34px;font-size:11px">${ini(c.name)}</div>
          <div><div style="font-size:14px;font-weight:500;color:#2E3751">${c.name}</div><div class="meta">${c.email}</div></div>
        </div>
        <button class="btn btn-ghost btn-sm" onclick="closePanel()" style="padding:4px 7px"><svg width="13" height="13" fill="currentColor" viewBox="0 0 20 20"><path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z"/></svg></button>
      </div>
    </div>
    <div class="sp-body">
      <div class="sg" style="grid-template-columns:1fr 1fr;gap:8px;margin-bottom:13px">
        ${[['Avg Score',c.score,scC(c.score)],['Total Calls',c.calls,'#2E3751'],['Call Time',c.callTime,'#2E3751'],['FU Missed',c.fuMissed,'#D92D20']].map(([l,v,col])=>`
          <div class="stat" style="padding:11px"><div class="stat-lbl">${l}</div><div style="font-size:18px;font-weight:500;color:${col};font-variant-numeric:tabular-nums">${v}</div></div>`).join('')}
      </div>
      <hr class="divider">
      ${[['mCube Number',c.mcube,true],['Onboarding Date',c.onboarding,false]].map(([l,v,m])=>`<div style="margin-bottom:11px"><div class="meta" style="margin-bottom:2px">${l}</div><div class="${m?'mono':''} body">${v}</div></div>`).join('')}
      <div style="margin-bottom:13px"><div class="meta" style="margin-bottom:3px">Status</div>${sp2(c.status)}</div>
      <hr class="divider">
      <button class="btn" style="width:100%;justify-content:center;font-size:12px">Edit Counsellor</button>
    </div>`);
}

function openAddCPanel(){
  openPanel(`
    <div class="sp-hdr"><div style="display:flex;justify-content:space-between;align-items:center">
      <div style="font-size:14px;font-weight:500;color:#2E3751">Create New Counsellor</div>
      <button class="btn btn-ghost btn-sm" onclick="closePanel()" style="padding:4px 7px"><svg width="13" height="13" fill="currentColor" viewBox="0 0 20 20"><path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z"/></svg></button>
    </div></div>
    <div class="sp-body">
      <div class="field"><label>Name <span class="req">*</span></label><input class="inp" style="width:100%" placeholder="Enter counsellor name"></div>
      <div class="field"><label>Email ID <span class="req">*</span></label><input class="inp" style="width:100%" type="email" placeholder="User email"></div>
      <div class="field"><label>mCube Number <span class="req">*</span></label><input class="inp" style="width:100%" type="tel" placeholder="+91"></div>
      <div class="field"><label>Onboarding Date <span class="req">*</span></label><input class="inp" style="width:100%" type="date"></div>
    </div>
    <div style="padding:10px 20px;border-top:1px solid #E2E4E8;display:flex;gap:7px;justify-content:flex-end">
      <button onclick="closePanel()" class="btn btn-sm">Cancel</button>
      <button onclick="closePanel()" class="btn btn-primary btn-sm">Add</button>
    </div>`);
}

function openAddKPanel(){
  openPanel(`
    <div class="sp-hdr"><div style="display:flex;justify-content:space-between;align-items:center">
      <div><div style="font-size:14px;font-weight:500;color:#2E3751">New KSP</div><div class="meta">Key Selling Point</div></div>
      <button class="btn btn-ghost btn-sm" onclick="closePanel()" style="padding:4px 7px"><svg width="13" height="13" fill="currentColor" viewBox="0 0 20 20"><path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z"/></svg></button>
    </div></div>
    <div class="sp-body">
      <div class="field"><label>Admission Season <span class="req">*</span></label><select class="inp" style="width:100%"><option>2025–2026</option></select></div>
      <div class="field"><label>KSP Name <span class="req">*</span></label><input class="inp" style="width:100%" placeholder="Ex: Early Admission Discount"></div>
      <div class="field"><label>Description <span class="req">*</span></label><textarea class="inp" style="width:100%" placeholder="Describe the key selling point..."></textarea></div>
      <div class="field"><label>Status <span class="req">*</span></label>
        <div style="display:flex;gap:7px">
          <button class="btn btn-primary btn-sm" id="kA" onclick="kSt('A')">Active</button>
          <button class="btn btn-sm" id="kI" onclick="kSt('I')">Inactive</button>
        </div>
      </div>
    </div>
    <div style="padding:10px 20px;border-top:1px solid #E2E4E8;display:flex;gap:7px;justify-content:flex-end">
      <button onclick="closePanel()" class="btn btn-sm">Cancel</button>
      <button onclick="closePanel()" class="btn btn-primary btn-sm">Add</button>
    </div>`);
}
function kSt(v){document.getElementById('kA').className=`btn btn-sm${v==='A'?' btn-primary':''}`;document.getElementById('kI').className=`btn btn-sm${v==='I'?' btn-primary':''}`;}

renderSB();renderPage();
</script>
