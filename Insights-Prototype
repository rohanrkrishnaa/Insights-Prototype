  const x=50+38*Math.cos(r(ang-90));const y=52+38*Math.sin(r(ang-90));
  return`<svg width="110" height="62" viewBox="0 0 100 60" style="overflow:visible">
    <path d="M12,56 A38,38 0 0,1 88,56" fill="none" stroke="#EDEFF2" stroke-width="7" stroke-linecap="round"/>
    <path d="M12,56 A38,38 0 0,1 ${x.toFixed(1)},${y.toFixed(1)}" fill="none" stroke="${c}" stroke-width="7" stroke-linecap="round"/>
    <text x="50" y="52" fill="${c}" font-family="Roboto,sans-serif" font-size="17" font-weight="500" text-anchor="middle">${score}</text>
    <text x="50" y="62" fill="#8B96AA" font-family="Roboto,sans-serif" font-size="7" text-anchor="middle">${lbl}</text>
