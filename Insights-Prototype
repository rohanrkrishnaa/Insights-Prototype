/* sparkline */
function spark(vals,color,h=28){
  const mx=Math.max(...vals),mn=Math.min(...vals);const w=60;
  const pts=vals.map((v,i)=>`${(i/(vals.length-1))*w},${h-((v-mn)/(mx-mn||1))*(h-4)+2}`).join(' ');
  return`<svg width="${w}" height="${h}" viewBox="0 0 ${w} ${h}"><polyline points="${pts}" fill="none" stroke="${color}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
}

/* gauge */
function gauge(score){
